#!/data/data/com.termux/files/usr/bin/bash

script_dir=$(cd "$(dirname "${BASH_SOURCE:-$0}")" && pwd) && readonly script_dir
# ogp_bin="${script_dir}/ogp" && readonly ogp_bin
# download_dir="/data/data/com.termux/files/home/storage/downloads" && readonly download_dir
log_file=$script_dir/termux-url-opener.log && readonly log_file
ogp_result=$script_dir/ogp.result.json && readonly ogp_result
# echo "$@" >>/data/data/com.termux/files/home/bin/log
# echo "$@" >>/data/data/com.termux/files/home/storage/downloads/termux-url-opener.log
#url_encode() { cat - |sed -e 's,^.*=,,g' -e 's,^.*/,,g' |curl -Gso /dev/null -w '%{url_effective}' --data-urlencode @- "" | cut -c 3-; }
#url_encode() { cat - |sed -e 's,^.*=,,g' -e 's,^.*/,,g'; }

has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done; }
_ink() { cat - | if has ink; then ink "$@"; else cat - 1>&2; fi; }
#_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") $(test -p /dev/stdin && cat -) ${@:2}" | _ink "$1"; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | tee -a "$log_file" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }

setup_and_check() {
  set -eo pipefail
  log "==> Checking required commands.."
  hass ogp jq curl am termux-chroot

  log "==> Removeing old log file: $log_file"
  rm -rf "$log_file"
  log "==> Starting termux-url-opener with arguments: $*"
  export PATH="$HOME/bin:$PATH"
  log "==> Loading environment variables from .env file.."
  # shellcheck disable=SC1091
  source "$script_dir"/.env
  if ! has termux-chroot; then
    error "No termux-chroot exist"
  fi
  if ! termux-chroot "test -e /etc/resolv.conf && grep nameserver /etc/resolv.conf" >&/dev/null; then
    termux-chroot "echo 'nameserver 8.8.8.8' >>/etc/resolv.conf /etc/resolv.conf"
  fi
}

start_ydl() {
  if ! pgrep ydl >&/dev/null; then
    # nohup termux-chroot /home/bin/ydl &
    nohup ~/bin/start_ydl &
  fi
  #url=$(echo "$@" |url_encode)
  url="$*"
  am start -a android.intent.action.VIEW -d "http://localhost:3000?uuid=me&url=$url"
}

fetch_ogp() {
  local org_url=$1
  log "==> Fetching OGP data for URL: $org_url"
  # res=$(termux-chroot X_COOKIE_JSON="$X_COOKIE_JSON" ogp "$org_url")
  # Pass $org_url as an env var so any shell metacharacters in the URL
  # cannot break out of the inner `bash -c` string.
  # shellcheck disable=SC2016 # $URL is expanded by the chroot-side bash -c, not here.
  termux-chroot env URL="$org_url" bash -c 'cd bin && . .env && ogp "$URL"' >"$ogp_result"
  local size
  size=$(wc -c <"$ogp_result")
  if ((size == 0)) || [[ $(cat "$ogp_result") == "[]" ]]; then
    error "Failed to fetch OGP data for URL: $org_url"
  fi
  log "==> OGP result:"
  jq . <"$ogp_result" | tee -a "$log_file" | _ink white
}

wait_for_user_exit() {
  # `read -r _` blocks for ENTER when a tty is attached; without a tty
  # (Android Intent invocation) just exit immediately.
  if [[ -t 0 ]]; then
    read -r _
  fi
  exit 1
}

run_mode() {
  # shellcheck disable=SC2154 # mode is set in .env (sourced in setup_and_check)
  case "$mode" in
    notion)
      log "==> Adding to Notion.."
      termux-chroot bash "$script_dir/to_notion.sh" "$ogp_result" 2>&1 | tee -a "$log_file" || {
        warn "==>Failed to execute Notion API request. Press Enter to exit."
        wait_for_user_exit
      }
      info "==>Successfully added to Notion"
      ;;
    gtasks)
      log "==> Adding to Google Tasks.."
      termux-chroot bash "$script_dir/to_gtasks.sh" "$ogp_result" 2>&1 | tee -a "$log_file" || {
        warn "==>Failed to execute Google Tasks API request. Press Enter to exit."
        wait_for_user_exit
      }
      info "==>Successfully added to Google Tasks"
      ;;
    keep)
      log "==> Adding to Google Keep.."
      bash "$script_dir/to_keep.sh" "$ogp_result" 2>&1 | tee -a "$log_file" || {
        warn "==>Failed to send to Google Keep. Press Enter to exit."
        wait_for_user_exit
      }
      info "==>Successfully sent to Google Keep"
      ;;
    *)
      error "Unknown mode: $mode"
      ;;
  esac
}

main() {
  local org_url=$1
  setup_and_check "$@"
  # start_ydl "$@"
  fetch_ogp "$org_url"
  run_mode
}
main "$@"
